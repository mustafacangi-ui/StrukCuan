# Required for production (set in Vercel Environment Variables)
VITE_SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
VITE_MAPBOX_TOKEN=YOUR_MAPBOX_PUBLIC_TOKEN

# Optional: Survey providers (CPX Research / Pollfish)
# VITE_CPX_APP_ID=your-cpx-app-id
# VITE_POLLFISH_API_KEY=your-pollfish-api-key

# Optional: BitLabs survey (Pro Survey & Partner Tasks)
# VITE_BITLABS_TOKEN=757953d0...

# Optional: Rewarded ad mediation (fallback to defaults in adNetworks.ts)
# VITE_ADSTERRA_SMARTLINK=https://your-adsterra-smartlink-url
# VITE_MONETAG_ZONE_LINK=https://omg10.com/4/10726900
# VITE_PROPELLER_DIRECT_LINK=https://your-propeller-direct-link

