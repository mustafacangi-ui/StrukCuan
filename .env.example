# Required for production (set in Vercel Environment Variables)
VITE_SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Canonical site URL — MUST include https:// (never "www.strukcuan.com" alone — breaks magic link redirects)
VITE_APP_URL=https://www.strukcuan.com
VITE_MAPBOX_TOKEN=YOUR_MAPBOX_PUBLIC_TOKEN

# Web Push Notifications - VAPID public key for PushManager.subscribe()
# Generate VAPID keys: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY_HERE

# CPX Research — sunucu only (VITE_ ile expose ETMEYİN). Anket listesi: /api/cpx-surveys
# CPX_APP_ID=your-cpx-app-id
# CPX_SECRET_KEY=your-cpx-secret-md5-for-user_id-hash-and-webhook

# CPX postback (Vercel: /api/webhooks/cpx-reward) — aynı CPX_SECRET_KEY kullanılabilir
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Teşhis: hash öncesi query/body dönmek için (işlem yapmaz); bitince kaldırın veya 0 yapın
# CPX_WEBHOOK_DEBUG=1
# VITE_POLLFISH_API_KEY=your-pollfish-api-key

# BitLabs survey API (required for surveys)
VITE_BITLABS_TOKEN=757953d0-69ca-4399-b843-6fecc027c333

# Optional: Rewarded ad mediation (fallback to defaults in adNetworks.ts)
# VITE_ADSTERRA_SMARTLINK=https://your-adsterra-smartlink-url
# VITE_MONETAG_ZONE_LINK=https://omg10.com/4/10726900
# VITE_PROPELLER_DIRECT_LINK=https://your-propeller-direct-link

