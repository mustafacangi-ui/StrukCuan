{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "header", "key": "host", "value": "struk-cuan.vercel.app" }],
      "destination": "https://www.strukcuan.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "header", "key": "host", "value": "strukcuan.com" }],
      "destination": "https://www.strukcuan.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
